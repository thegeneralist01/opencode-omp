{
  "name": "opencode-omp",
  "version": "1.0.0",
  "description": "Bridge OpenCode CLI free models into OMP without OpenCode login",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "omp": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "omp-package",
    "omp",
    "oh-my-pi",
    "opencode",
    "free-models",
    "custom-provider"
  ],
  "author": "opencode-omp contributors",
  "license": "MIT",
  "peerDependencies": {
    "@oh-my-pi/pi-coding-agent": ">=16.0.0",
    "@oh-my-pi/pi-ai": ">=16.0.0"
  },
  "devDependencies": {
    "@oh-my-pi/pi-ai": ">=16.0.0",
    "@oh-my-pi/pi-coding-agent": ">=16.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
